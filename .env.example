# Local Vite development:
# HA_BASE_URL stays on the dev server side. VITE_HA_BASE_URL is supported
# only as a legacy local-dev fallback; prefer HA_BASE_URL for new setups.
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=your_home_assistant_long_lived_access_token
VITE_ENABLE_HA=true

# Vercel production:
HA_BASE_URL=https://your-home-assistant.example.com
HA_TOKEN=your_home_assistant_long_lived_access_token
# Optional frontend overrides:
# VITE_ENABLE_HA=false
# VITE_HA_API_BASE_PATH=/api/ha
